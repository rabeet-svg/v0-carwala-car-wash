                    "preference": "default"
                },
                "cascade_timeout_seconds": 8,
                "tools": [
                    {
                        "type": "webhook",
                        "name": "check_slots",
                        "description": "Check available appointment slots for a given service and date range",
                        "api_schema": {
                            "url": "https://carwala.org/api/agent/slots",
                            "method": "GET",
                            "headers": {
                                "x-agent-token": "8axw4pEoXcnG7fYbe6SzB0lkq512HPhW"
                            },
                            "query_params_schema": {
                                "properties": {
                                    "eventTypeId": { "type": "string", "description": "The Cal.com event type ID for the service" },
                                    "dateFrom": { "type": "string", "description": "Start date in YYYY-MM-DD format" },
                                    "dateTo": { "type": "string", "description": "End date in YYYY-MM-DD format" }
                                },
                                "required": ["eventTypeId", "dateFrom", "dateTo"]
                            }
                        }
                    },
                    {
                        "type": "webhook",
                        "name": "book_appointment",
                        "description": "Book a car detailing appointment for the customer",
                        "api_schema": {
                            "url": "https://carwala.org/api/agent/book",
                            "method": "POST",
                            "headers": {
                                "x-agent-token": "8axw4pEoXcnG7fYbe6SzB0lkq512HPhW",
                                "Content-Type": "application/json"
                            },
                            "request_body_schema": {
                                "type": "object",
                                "properties": {
                                    "eventTypeId": { "type": "string", "description": "The Cal.com event type ID" },
                                    "start": { "type": "string", "description": "ISO 8601 datetime string" },
                                    "name": { "type": "string", "description": "Customer full name" },
                                    "phone": { "type": "string", "description": "Customer phone number" },
                                    "email": { "type": "string", "description": "Customer email (optional)" },
                                    "notes": { "type": "string", "description": "Additional notes" }
                                },
                                "required": ["eventTypeId", "start", "name"]
                            }
                        }
                    },
                    {
                        "type": "webhook",
                        "name": "cancel_appointment",
                        "description": "Cancel an existing appointment",
                        "api_schema": {
                            "url": "https://carwala.org/api/agent/cancel",
                            "method": "POST",
                            "headers": {
                                "x-agent-token": "8axw4pEoXcnG7fYbe6SzB0lkq512HPhW",
                                "Content-Type": "application/json"
                            },
                            "request_body_schema": {
                                "type": "object",
                                "properties": {
                                    "bookingUid": { "type": "string", "description": "The booking UID from Cal.com" },
                                    "reason": { "type": "string", "description": "Reason for cancellation" }
                                },
                                "required": ["bookingUid"]
                            }
                        }
                    },
                    {
                        "type": "webhook",
                        "name": "reschedule_appointment",
                        "description": "Reschedule an existing appointment to a new time",
                        "api_schema": {
                            "url": "https://carwala.org/api/agent/reschedule",
                            "method": "POST",
                            "headers": {
                                "x-agent-token": "8axw4pEoXcnG7fYbe6SzB0lkq512HPhW",
                                "Content-Type": "application/json"
                            },
                            "request_body_schema": {
                                "type": "object",
                                "properties": {
                                    "bookingUid": { "type": "string", "description": "The booking UID from Cal.com" },
                                    "start": { "type": "string", "description": "New ISO 8601 datetime string" },
                                    "reason": { "type": "string", "description": "Reason for rescheduling" }
                                },
                                "required": ["bookingUid", "start"]
                            }
                        }
                    },
                    {
                        "type": "system",
